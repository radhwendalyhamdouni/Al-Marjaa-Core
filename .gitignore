# ═══════════════════════════════════════════════════════════════════════════════
# لغة المرجع - Al-Marjaa Language
# ملف .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ═══════════════════════════════════════════════════════════════════════════════
# Rust Build Artifacts
# ═══════════════════════════════════════════════════════════════════════════════
/target/
**/*.rs.bk
Cargo.lock

# ═══════════════════════════════════════════════════════════════════════════════
# IDE & Editor Files
# ═══════════════════════════════════════════════════════════════════════════════
.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-workspace
*.sublime-project

# ═══════════════════════════════════════════════════════════════════════════════
# OS Generated Files
# ═══════════════════════════════════════════════════════════════════════════════
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ═══════════════════════════════════════════════════════════════════════════════
# Test & Coverage
# ═══════════════════════════════════════════════════════════════════════════════
/coverage/
*.profraw
*.profdata
lcov.info
*.gcov
*.gcno
*.gcda

# ═══════════════════════════════════════════════════════════════════════════════
# Fuzzing
# ═══════════════════════════════════════════════════════════════════════════════
/fuzz/target/
/fuzz/artifacts/
/fuzz/corpus/

# ═══════════════════════════════════════════════════════════════════════════════
# Documentation
# ═══════════════════════════════════════════════════════════════════════════════
/doc/
/target/doc/

# ═══════════════════════════════════════════════════════════════════════════════
# Temporary & Cache
# ═══════════════════════════════════════════════════════════════════════════════
*.tmp
*.temp
*.log
*.bak
*.cache
__pycache__/
.node_modules/

# ═══════════════════════════════════════════════════════════════════════════════
# Binary & Executable
# ═══════════════════════════════════════════════════════════════════════════════
*.exe
*.dll
*.so
*.dylib
*.a
*.lib
