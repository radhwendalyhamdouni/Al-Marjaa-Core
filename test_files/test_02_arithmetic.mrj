# اختبار العمليات الحسابية
# Arithmetic Operations Test

متغير أ = 10؛
متغير ب = 3؛

متغير جمع = أ + ب؛
متغير طرح = أ - ب؛
متغير ضرب = أ * ب؛
متغير قسمة = أ / ب؛
متغير باقي = أ % ب؛

اطبع("الجمع: " + نص(جمع))؛
اطبع("الطرح: " + نص(طرح))؛
اطبع("الضرب: " + نص(ضرب))؛
اطبع("القسمة: " + نص(قسمة))؛
اطبع("الباقي: " + نص(باقي))؛

# أولوية العمليات
متغير نتيجة1 = 2 + 3 * 4؛
متغير نتيجة2 = (2 + 3) * 4؛
متغير نتيجة3 = 10 - 2 - 3؛

اطبع("أولوية 1: " + نص(نتيجة1))؛
اطبع("أولوية 2: " + نص(نتيجة2))؛
اطبع("أولوية 3: " + نص(نتيجة3))؛
