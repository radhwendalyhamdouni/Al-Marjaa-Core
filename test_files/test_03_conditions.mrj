# اختبار الشروط
# Conditions Test

متغير درجة = 85؛

إذا درجة >= 90 {
    اطبع("ممتاز")؛
} وإلا إذا درجة >= 80 {
    اطبع("جيد جداً")؛
} وإلا إذا درجة >= 70 {
    اطبع("جيد")؛
} وإلا إذا درجة >= 60 {
    اطبع("مقبول")؛
} وإلا {
    اطبع("راسب")؛
}

# اختبار المنطق
متغير أ = صح؛
متغير ب = خطأ؛

إذا أ و ليس ب {
    اطبع("الشرط صحيح")؛
}

إذا أ أو ب {
    اطبع("أحد الشرطين صحيح")؛
}

إذا ليس ب {
    اطبع("ب خاطئ")؛
}

# اختبار المقارنة
متغير س = 5؛
متغير ص = 10؛

إذا س < ص {
    اطبع("س أصغر من ص")؛
}

إذا س <= 5 {
    اطبع("س أصغر أو يساوي 5")؛
}

إذا ص != س {
    اطبع("ص لا تساوي س")؛
}
