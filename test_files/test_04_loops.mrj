# اختبار الحلقات
# Loops Test

# حلقة طالما
اطبع("=== حلقة طالما ===")؛
متغير عداد = 1؛
طالما عداد <= 5 {
    اطبع("العدد: " + نص(عداد))؛
    عداد = عداد + 1؛
}

# حلقة لكل
اطبع("=== حلقة لكل ===")؛
متغير أرقام = [10, 20, 30, 40, 50]؛
لكل رقم في أرقام {
    اطبع("الرقم: " + نص(رقم))؛
}

# حلقة متداخلة
اطبع("=== حلقة متداخلة ===")؛
متغير أي = 1؛
طالما أي <= 3 {
    متغير ج = 1؛
    طالما ج <= 3 {
        اطبع(نص(أي) + " × " + نص(ج) + " = " + نص(أي * ج))؛
        ج = ج + 1؛
    }
    أي = أي + 1؛
}
