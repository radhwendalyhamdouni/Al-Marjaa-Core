# اختبار الدوال
# Functions Test

# دالة بسيطة
دالة ترحيب() {
    اطبع("مرحباً بك في لغة المرجع!")؛
}

ترحيب()؛

# دالة مع معاملات
دالة جمع(أ، ب) {
    أرجع أ + ب؛
}

متغير نتيجة = جمع(5, 3)؛
اطبع("5 + 3 = " + نص(نتيجة))؛

# دالة عودية
دالة مضروب(ن) {
    إذا ن <= 1 {
        أرجع 1؛
    }
    أرجع ن * مضروب(ن - 1)؛
}

اطبع("مضروب 5 = " + نص(مضروب(5)))؛

# دالة داخل دالة
دالة خارج() {
    متغير رسالة = "مرحباً"؛
    دالة داخل() {
        اطبع(رسالة + " من الداخل")؛
    }
    داخل()؛
}

خارج()؛
