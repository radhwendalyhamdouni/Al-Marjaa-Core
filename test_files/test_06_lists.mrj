# اختبار القوائم
# Lists Test

# إنشاء قائمة
متغير فواكه = ["تفاح", "موز", "برتقال", "عنب"]؛
اطبع("الفواكه: " + نص(فواكه))؛

# الوصول للعناصر
اطبع("أول فاكهة: " + فواكه[0])؛
اطبع("ثاني فاكهة: " + فواكه[1])؛

# طول القائمة
اطبع("عدد الفواكه: " + نص(طول(فواكه)))؛

# قائمة أرقام
متغير أرقام = [1, 2, 3, 4, 5]؛
متغير مجموع = 0؛
لكل رقم في أرقام {
    مجموع = مجموع + رقم؛
}
اطبع("مجموع الأرقام: " + نص(مجموع))؛

# قائمة متداخلة
متغير مصفوفة = [[1, 2, 3], [4, 5, 6], [7, 8, 9]]؛
اطبع("العنصر [1][1]: " + نص(مصفوفة[1][1]))؛
