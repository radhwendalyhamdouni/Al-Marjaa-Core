# اختبار القواميس
# Dictionaries Test

# إنشاء قاموس
متغير شخص = {
    "اسم": "أحمد",
    "عمر": 30,
    "مدينة": "دمشق",
    "نشط": صح
}؛

اطبع("الشخص: " + نص(شخص))؛

# الوصول للقيم
اطبع("الاسم: " + شخص["اسم"])؛
اطبع("العمر: " + نص(شخص["عمر"]))؛

# تعديل القيم
شخص["عمر"] = 31؛
اطبع("العمر الجديد: " + نص(شخص["عمر"]))؛

# إضافة قيم جديدة
شخص["مهنة"] = "مبرمج"؛
اطبع("بعد الإضافة: " + نص(شخص))؛

# قاموس متداخل
متغير شركة = {
    "اسم": "شركة التقنية",
    "عنوان": {
        "مدينة": "دمشق",
        "شارع": "الجامعة"
    }
}؛

اطبع("اسم الشركة: " + شركة["اسم"])؛
اطبع("المدينة: " + شركة["عنوان"]["مدينة"])؛
