# اختبار النصوص
# Strings Test

متغير نص1 = "مرحباً"؛
متغير نص2 = " بالعالم"؛
متغير نص3 = نص1 + نص2؛

اطبع("النص المدمج: " + نص3)؛
اطبع("طول النص: " + نص(طول(نص3)))؛

# نص متعدد الأسطر
متغير نص_متعدد = """
هذا نص
متعدد الأسطر
في لغة المرجع
"""؛
اطبع("النص المتعدد:" + نص_متعدد)؛

# مقارنة النصوص
متغير أ = "abc"؛
متغير ب = "abc"؛
متغير ج = "ABC"؛

إذا أ == ب {
    اطبع("أ يساوي ب")؛
}

إذا أ != ج {
    اطبع("أ لا يساوي ج")؛
}
