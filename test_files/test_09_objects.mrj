# اختبار الكائنات والقواميس
# Objects and Dictionaries Test

# قاموس بسيط
متغير شخص = {
    "اسم": "أحمد"،
    "عمر": 30
}؛

اطبع("الاسم: " + شخص["اسم"])؛
اطبع("العمر: " + نص(شخص["عمر"]))؛

# تعديل القيم
شخص["عمر"] = 31؛
اطبع("العمر الجديد: " + نص(شخص["عمر"]))؛

# قاموس متداخل
متغير شركة = {
    "اسم": "شركة التقنية"،
    "عنوان": {
        "مدينة": "دمشق"
    }
}؛

اطبع("اسم الشركة: " + شركة["اسم"])؛
