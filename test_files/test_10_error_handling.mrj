# اختبار معالجة الأخطاء
# Error Handling Test

# حاول - امسك
حاول {
    متغير نتيجة = 10 / 0؛
    اطبع("النتيجة: " + نص(نتيجة))؛
} امسك (سبب) {
    اطبع("حدث خطأ: تم القسمة على صفر")؛
}

# إلقاء خطأ
دالة التحقق_من_العمر(عمر) {
    إذا عمر < 0 {
        اطرح "العمر لا يمكن أن يكون سالباً"؛
    }
    إذا عمر > 150 {
        اطرح "العمر غير منطقي"؛
    }
    أرجع صح؛
}

حاول {
    التحقق_من_العمر(-5)؛
} امسك (سبب) {
    اطبع("خطأ التحقق: العمر سالب")؛
}

# التحقق الصحيح
حاول {
    متغير صحيح = التحقق_من_العمر(25)؛
    اطبع("التحقق صحيح: " + نص(صحيح))؛
} امسك (سبب) {
    اطبع("خطأ غير متوقع")؛
}
