# اختبار الخوارزميات المتقدمة
# Advanced Algorithms Test

# فيبوناتشي التكراري
دالة فيبوناتشي_تكراري(ن) {
    إذا ن <= 1 {
        أرجع ن؛
    }
    أرجع فيبوناتشي_تكراري(ن - 1) + فيبوناتشي_تكراري(ن - 2)؛
}

اطبع("=== فيبوناتشي التكراري ===")؛
متغير أي = 0؛
طالما أي <= 10 {
    اطبع("fib(" + نص(أي) + ") = " + نص(فيبوناتشي_تكراري(أي)))؛
    أي = أي + 1؛
}

# فيبوناتشي المحسن
دالة فيبوناتشي(ن) {
    إذا ن <= 1 {
        أرجع ن؛
    }
    متغير أ = 0؛
    متغير ب = 1؛
    متغير نتيجة = 0؛
    متغير عدد = 2؛
    طالما عدد <= ن {
        نتيجة = أ + ب؛
        أ = ب؛
        ب = نتيجة؛
        عدد = عدد + 1؛
    }
    أرجع ب؛
}

اطبع("=== فيبوناتشي المحسن ===")؛
اطبع("fib(20) = " + نص(فيبوناتشي(20)))؛
اطبع("fib(30) = " + نص(فيبوناتشي(30)))؛

# حساب المجموع
دالة مجموع(عناصر) {
    متغير نتيجة = 0؛
    لكل عنصر في عناصر {
        نتيجة = نتيجة + عنصر؛
    }
    أرجع نتيجة؛
}

# حساب المتوسط
دالة متوسط(عناصر) {
    أرجع مجموع(عناصر) / طول(عناصر)؛
}

متغير درجات = [85, 92, 78, 90, 88]؛
اطبع("=== الإحصائيات ===")؛
اطبع("الدرجات: " + نص(درجات))؛
اطبع("المجموع: " + نص(مجموع(درجات)))؛
اطبع("المتوسط: " + نص(متوسط(درجات)))؛
