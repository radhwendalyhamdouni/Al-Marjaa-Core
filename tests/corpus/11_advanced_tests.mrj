// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات المكتبات المتقدمة - Advanced Library Tests
// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات شاملة للمكتبات القياسية الجديدة

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات مكتبة النصوص
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("=== اختبارات مكتبة النصوص ===")؛

// اختبار التحويل
متغير نص_تجريبي = "مرحبا بالعالم"؛
تأكد_يساوي(أول_كبير("محمد")، "محمد"، "الحرف الأول كبير")؛
تأكد_يساوي(كبير("abc")، "ABC"، "تحويل لكبير")؛
تأكد_يساوي(صغير("ABC")، "abc"، "تحويل لصغير")؛

// اختبار البحث
تأكد(يحتوي("مرحبا بالعالم"، "بالعالم")، "البحث عن نص")؛
تأكد(يبدأ_بـ("مرحبا"، "مر")، "البدء بنص")؛
تأكد(ينتهي_بـ("مرحبا"، "با")، "الانتهاء بنص")؛

// اختبار التنظيف
تأكد_يساوي(قلم("  مرحبا  ")، "مرحبا"، "إزالة المسافات")؛
تأكد_يساوي(ضغط_المسافات("مرحبا    بالعالم")، "مرحبا بالعالم"، "ضغط المسافات")؛

// اختبار الحشو
تأكد_يساوي(حشو_يسار("5"، 3، "0")، "005"، "حشو من اليسار")؛
تأكد_يساوي(حشو_يمين("5"، 3، "0")، "500"، "حشو من اليمين")؛
تأكد_يساوي(توسيط("أ"، 3)، " أ "، "توسيط النص")؛

// اختبارات العربية
متغير أرقام = أرقام_عربية("123")؛
تأكد_يساوي(أرقام، "١٢٣"، "تحويل للأرقام العربية")؛
تأكد_يساوي(أرقام_هندية(أرقام)، "123"، "تحويل للأرقام الهندية")؛

// اختبار التنسيق
تأكد_يساوي(تنسيق_رقم(1234.5)، "1،234.5"، "تنسيق رقم")؛
تأكد_يساوي(تنسيق_عملة(100)، "100.00 ر.س"، "تنسيق عملة")؛
تأكد_يساوي(تنسيق_نسبة(0.75)، "75.0%"، "تنسيق نسبة")؛

اطبع("✓ تم اجتياز اختبارات مكتبة النصوص")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات مكتبة المصفوفات
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("=== اختبارات مكتبة المصفوفات ===")؛

// اختبار الإنشاء
متغير أرقام_نطاق = نطاق(1، 5)؛
تأكد_يساوي(طول(أرقام_نطاق)، 4، "إنشاء نطاق")؛
تأكد_يساوي(طول(أصفار(5))، 5، "إنشاء أصفار")؛

// اختبار الإحصاء
متغير بيانات = [1، 2، 3، 4، 5]؛
تأكد_يساوي(مجموع(بيانات)، 15، "حساب المجموع")؛
تأكد_يساوي(متوسط(بيانات)، 3، "حساب المتوسط")؛
تأكد_يساوي(أكبر(بيانات)، 5، "إيجاد الأكبر")؛
تأكد_يساوي(أصغر(بيانات)، 1، "إيجاد الأصغر")؛

// اختبار الترتيب
متغير غير_مرتب = [3، 1، 4، 1، 5]؛
متغير مرتب = رتب(غير_مرتب)؛
تأكد_يساوي(مرتب[0]، 1، "الترتيب التصاعدي")؛
تأكد_يساوي(رتب_عكس(غير_مرتب)[0]، 5، "الترتيب التنازلي")؛

// اختبار الفلترة والخريطة
متغير مضاعفات = خريطة([1، 2، 3]، |س| س * 2)؛
تأكد_يساوي(مضاعفات[1]، 4، "خريطة الضرب")؛

متغير أكبر_من_2 = صفّ([1، 2، 3، 4، 5]، |س| س > 2)؛
تأكد_يساوي(طول(أكبر_من_2)، 3، "فلترة أكبر من 2")؛

// اختبار التحديد
متغير مع_تكرار = [1، 2، 2، 3، 3، 3]؛
تأكد_يساوي(طول(فريد(مع_تكرار))، 3، "إزالة التكرارات")؛

// اختبار التقاطع والاتحاد
متغير قائمة1 = [1، 2، 3]؛
متغير قائمة2 = [2، 3، 4]؛
تأكد_يساوي(طول(اتحاد(قائمة1، قائمة2))، 4، "الاتحاد")؛
تأكد_يساوي(طول(تقاطع(قائمة1، قائمة2))، 2، "التقاطع")؛
تأكد_يساوي(طول(فرق(قائمة1، قائمة2))، 1، "الفرق")؛

// اختبار التقسيم
متغير مقسم = جزّئ([1، 2، 3، 4، 5، 6]، 2)؛
تأكد_يساوي(طول(مقسم)، 3، "التقسيم لأجزاء")؛

اطبع("✓ تم اجتياز اختبارات مكتبة المصفوفات")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات مكتبة الرياضيات
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("=== اختبارات مكتبة الرياضيات ===")؛

// اختبار الثوابت
تأكد(PI > 3.14 و PI < 3.15، "قيمة PI")؛
تأكد(E > 2.71 و E < 2.72، "قيمة E")؛

// اختبار الدوال الأساسية
تأكد_يساوي(مطلق(-5)، 5، "القيمة المطلقة")؛
تأكد_يساوي(تقريب(3.7)، 4، "التقريب")؛
تأكد_يساوي(أعلى(3.2)، 4، "السقف")؛
تأكد_يساوي(أدنى(3.8)، 3، "الأرضية")؛

// اختبار الأسس والجذور
تأكد_يساوي(أس(2، 3)، 8، "الأس")؛
تأكد_يساوي(جذر(9)، 3، "الجذر التربيعي")؛

// اختبار المضروب
تأكد_يساوي(مضروب(5)، 120، "المضروب")؛
تأكد_يساوي(مضروب(0)، 1، "مضروب الصفر")؛

// اختبار التوافيق والتباديل
تأكد_يساوي(توافيق(5، 2)، 10، "التوافيق")؛
تأكد_يساوي(تباديل(5، 2)، 20، "التباديل")؛

// اختبار الأعداد الأولية
تأكد(أولي(7)، "العدد 7 أولي")؛
تأكد(ليس أولي(4)، "العدد 4 غير أولي")؛

// اختبار فيبوناتشي
تأكد_يساوي(فيبوناتشي(10)، 55، "فيبوناتشي")؛

// اختبار القاسم والمضاعف
تأكد_يساوي(قاسم_مشترك(12، 8)، 4، "القاسم المشترك")؛
تأكد_يساوي(مضاعف_مشترك(4، 6)، 12، "المضاعف المشترك")؛

اطبع("✓ تم اجتياز اختبارات مكتبة الرياضيات")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات JSON
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("=== اختبارات JSON ===")؛

// اختبار التشفير
متغير كائن = {اسم: "محمد"، عمر: 25}؛
متغير json_نص = تشفير(كائن)؛
تأكد(يحتوي(json_نص، "محمد")، "تشفير JSON")؛

// اختبار فك التشفير
متغير json_مدخل = "{\"اسم\":\"أحمد\",\"عمر\":30}"؛
متغير الكائن = فك_التشفير(json_مدخل)؛
تأكد_يساوي(الكائن.عمر، 30، "فك تشفير JSON")؛

// اختبار الصحة
تأكد(صالح("{\"a\":1}")، "JSON صالح")؛
تأكد(ليس صالح("{invalid}")، "JSON غير صالح")؛

اطبع("✓ تم اجتياز اختبارات JSON")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات الدوال المتقدمة
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("=== اختبارات الدوال المتقدمة ===")؛

// اختبار الدوال السهمية
دالة ضعف(س) = س * 2؛
تأكد_يساوي(ضعف(5)، 10، "دالة السهم")؛

// اختبار الإغلاق
دالة أنشئ_عداد():
    متغير عدد = 0؛
    أرجع ||:
        عدد = عدد + 1؛
        أرجع عدد؛
    ؛
؛

متغير العداد = أنشئ_عداد()؛
تأكد_يساوي(العداد()، 1، "العداد - النداء الأول")؛
تأكد_يساوي(العداد()، 2، "العداد - النداء الثاني")؛

// اختبار التكرار
دالة عاملي(ن):
    إذا ن <= 1:
        أرجع 1؛
    أرجع ن * عاملي(ن - 1)؛
؛

تأكد_يساوي(عاملي(5)، 120، "الدالة العودية")؛

اطبع("✓ تم اجتياز اختبارات الدوال المتقدمة")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات الكائنات والأصناف
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("=== اختبارات الكائنات والأصناف ===")؛

// تعريف صنف
صنف شخص:
    متغير الاسم = ""؛
    متغير العمر = 0؛
    
    دالة جديد(الاسم، العمر):
        هذا.الاسم = الاسم؛
        هذا.العمر = العمر؛
        أرجع هذا؛
    ؛
    
    دالة عرّف():
        أرجع هذا.الاسم + " - " + نص(هذا.العمر) + " سنة"؛
    ؛
؛

متغير الشخص = شخص.جديد("علي"، 30)؛
تأكد_يساوي(الشخص.الاسم، "علي"، "إنشاء كائن")؛
تأكد(يحتوي(الشخص.عرّف()، "علي")، "استدعاء دالة الكائن")؛

اطبع("✓ تم اجتياز اختبارات الكائنات والأصناف")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات معالجة الأخطاء
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("=== اختبارات معالجة الأخطاء ===")؛

// اختبار حاول-امسك
متغير نجح = خطأ؛
حاول:
    متغير نتيجة = 10 / 0؛
امسك الخطأ:
    نجح = صح؛
؛
تأكد(نجح، "التقاط خطأ القسمة على صفر")؛

// اختبار إلقاء خطأ
متغير تم_الإمساك = خطأ؛
حاول:
    ألقِ "خطأ تجريبي"؛
امسك:
    تم_الإمساك = صح؛
؛
تأكد(تم_الإمساك، "إلقاء والإمساك بخطأ")؛

اطبع("✓ تم اجتياز اختبارات معالجة الأخطاء")؛

