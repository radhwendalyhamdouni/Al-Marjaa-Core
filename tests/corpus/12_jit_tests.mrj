// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات الأداء الأساسية
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("")؛
اطبع("▶ اختبارات الأداء الأساسية:")؛

// اختبار حلقة بسيطة
متغير بداية = الآن()؛
متغير مجموع_حلقة = 0؛
لكل س من 1 إلى 100000:
    مجموع_حلقة = مجموع_حلقة + س؛
متغير نهاية = الآن()؛
متغير زمن_الحلقة = (نهاية - بداية) * 1000؛
اطبع("  • حلقة 100,000 تكرار: " + تنسيق_رقم(زمن_الحلقة) + " مللي ثانية")؛

// اختبار الحسابات الرياضية
بداية = الآن()؛
متغير نتائج = []؛
لكل س من 1 إلى 10000:
    نتائج.أضف(جذر(س) * أس(س، 0.5))؛
نهاية = الآن()؛
متغير زمن_الرياضيات = (نهاية - بداية) * 1000؛
اطبع("  • 10,000 عملية رياضية: " + تنسيق_رقم(زمن_الرياضيات) + " مللي ثانية")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات فيبوناتشي
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("")؛
اطبع("▶ اختبارات فيبوناتشي:")؛

// فيبوناتشي التكراري
دالة فيبوناتشي_تكراري(ن):
    إذا ن <= 1:
        أرجع ن؛
    أرجع فيبوناتشي_تكراري(ن - 1) + فيبوناتشي_تكراري(ن - 2)؛
؛

// فيبوناتشي التكرار
دالة فيبوناتشي_تكرار(ن):
    إذا ن <= 1:
        أرجع ن؛
    متغير أ = 0؛
    متغير ب = 1؛
    لكل س من 2 إلى ن:
        متغير مؤقت = أ + ب؛
        أ = ب؛
        ب = مؤقت؛
    أرجع ب؛
؛

// قياس الأداء
بداية = الآن()؛
متغير fib_iter = فيبوناتشي_تكرار(35)؛
نهاية = الآن()؛
اطبع("  • فيبوناتشي(35) تكراري: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات الذاكرة والكائنات
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("")؛
اطبع("▶ اختبارات الذاكرة والكائنات:")؛

// إنشاء كائنات متعددة
صنف نقطة:
    متغير س = 0؛
    متغير ص = 0؛
    دالة جديد(س، ص):
        هذا.س = س؛
        هذا.ص = ص؛
        أرجع هذا؛
    ؛
    دالة مسافة(الأخرى):
        أرجع جذر((هذا.س - الأخرى.س)^2 + (هذا.ص - الأخرى.ص)^2)؛
    ؛
؛

بداية = الآن()؛
متغير نقاط = []؛
لكل س من 1 إلى 1000:
    نقاط.أضف(نقطة.جديد(س، س * 2))؛
نهاية = الآن()؛
اطبع("  • إنشاء 1,000 كائن: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// حساب المسافات
بداية = الآن()؛
متغير مجموع_مسافات = 0؛
لكل س من 0 إلى طول(نقاط) - 2:
    مجموع_مسافات = مجموع_مسافات + نقاط[س].مسافة(نقاط[س + 1])؛
نهاية = الآن()؛
اطبع("  • حساب 999 مسافة: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات معالجة النصوص
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("")؛
اطبع("▶ اختبارات معالجة النصوص:")؛

// إنشاء نص طويل
متغير نص_طويل = ""؛
لكل س من 1 إلى 1000:
    نص_طويل = نص_طويل + "مرحبا بالعالم "؛

بداية = الآن()؛
متغير كلمات_نص = تقسيم(نص_طويل، " ")؛
نهاية = الآن()؛
اطبع("  • تقسيم نص طويل: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// البحث في النص
بداية = الآن()؛
متغير موضع = موقع(نص_طويل، "العالم")؛
نهاية = الآن()؛
اطبع("  • بحث في نص طويل: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات القوائم والخوارزميات
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("")؛
اطبع("▶ اختبارات القوائم والخوارزميات:")؛

// إنشاء قائمة كبيرة
بداية = الآن()؛
متغير قائمة_كبيرة = []؛
لكل س من 1 إلى 10000:
    قائمة_كبيرة.أضف(عشوائي_صحيح(1، 10000))؛
نهاية = الآن()؛
اطبع("  • إنشاء قائمة 10,000 عنصر: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// ترتيب القائمة
بداية = الآن()؛
متغير مرتبة = رتب(قائمة_كبيرة)؛
نهاية = الآن()؛
اطبع("  • ترتيب 10,000 عنصر: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// البحث الخطي
بداية = الآن()؛
متغير موجود = يحتوي(قائمة_كبيرة، 5000)؛
نهاية = الآن()؛
اطبع("  • بحث خطي: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات الدوال العالية الترتيب
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("")؛
اطبع("▶ اختبارات الدوال العالية الترتيب:")؛

// خريطة
بداية = الآن()؛
متغير مربعات = خريطة(نطاق(1، 10001)، |س| س * س)؛
نهاية = الآن()؛
اطبع("  • خريطة على 10,000 عنصر: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// فلترة
بداية = الآن()؛
متغير زوجية = صفّ(نطاق(1، 10001)، |س| س % 2 == 0)؛
نهاية = الآن()؛
اطبع("  • فلترة 10,000 عنصر: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات التخصيم (Reduce)
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("")؛
اطبع("▶ اختبارات التخصيم:")؛

// حساب المجموع
بداية = الآن()؛
متغير المجموع = مجموع(نطاق(1، 100001))؛
نهاية = الآن()؛
اطبع("  • مجموع 100,000 رقم: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// التحقق من النتيجة
متغير المجموع_المتوقع = (100000 * 100001) / 2؛
تأكد_يساوي(المجموع، المجموع_المتوقع، "صحة حساب المجموع")؛

// ═══════════════════════════════════════════════════════════════════════════════
// اختبارات الاستدعاء الذاتي
// ═══════════════════════════════════════════════════════════════════════════════

اطبع("")؛
اطبع("▶ اختبارات الاستدعاء الذاتي:")؛

// حساب المضروب بشكل عودي
دالة مضروب_عودي(ن):
    إذا ن <= 1:
        أرجع 1؛
    أرجع ن * مضروب_عودي(ن - 1)؛
؛

بداية = الآن()؛
متغير المضروب = مضروب_عودي(20)؛
نهاية = الآن()؛
اطبع("  • مضروب(20) عودي: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

// بحث ثنائي
دالة بحث_ثنائي(القائمة، الهدف):
    متغير منخفض = 0؛
    متغير مرتفع = طول(القائمة) - 1؛
    طالما منخفض <= مرتفع:
        متغير المتوسط = (منخفض + مرتفع) // 2؛
        إذا القائمة[المتوسط] == الهدف:
            أرجع المتوسط؛
        وإذا القائمة[المتوسط] < الهدف:
            منخفض = المتوسط + 1؛
        وإلا:
            مرتفع = المتوسط - 1؛
    أرجع -1؛
؛

بداية = الآن()؛
متغير الفهرس = بحث_ثنائي(مرتبة، مرتبة[5000])؛
نهاية = الآن()؛
اطبع("  • بحث ثنائي: " + تنسيق_رقم((نهاية - بداية) * 1000) + " مللي ثانية")؛

