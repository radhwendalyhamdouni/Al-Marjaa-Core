{
  "Function Definition": {
    "prefix": "دالة",
    "body": [
      "دالة ${1:اسم_الدالة}(${2:معاملات}) {",
      "\t$3",
      "\tأرجع ${4:النتيجة}؛",
      "}"
    ],
    "description": "تعريف دالة جديدة"
  },
  "Function Definition Short": {
    "prefix": "fn",
    "body": [
      "دالة ${1:func_name}(${2:params}) {",
      "\t$3",
      "\tأرجع ${4:result}؛",
      "}"
    ],
    "description": "Define a new function"
  },
  "Variable Declaration": {
    "prefix": "متغير",
    "body": [
      "متغير ${1:اسم_المتغير} = ${2:القيمة}؛"
    ],
    "description": "تعريف متغير جديد"
  },
  "Variable Short": {
    "prefix": "م",
    "body": [
      "م ${1:var} = ${2:value}؛"
    ],
    "description": "تعريف متغير (مختصر)"
  },
  "Constant Declaration": {
    "prefix": "ثابت",
    "body": [
      "ثابت ${1:اسم_الثابت} = ${2:القيمة}؛"
    ],
    "description": "تعريف ثابت جديد"
  },
  "Constant Short": {
    "prefix": "ث",
    "body": [
      "ث ${1:CONST} = ${2:value}؛"
    ],
    "description": "تعريف ثابت (مختصر)"
  },
  "If Statement": {
    "prefix": "إذا",
    "body": [
      "إذا (${1:الشرط}) {",
      "\t$2",
      "}"
    ],
    "description": "جملة شرطية"
  },
  "If Else Statement": {
    "prefix": "إذا_وإلا",
    "body": [
      "إذا (${1:الشرط}) {",
      "\t$2",
      "} وإلا {",
      "\t$3",
      "}"
    ],
    "description": "جملة شرطية مع بديل"
  },
  "If ElseIf Else Statement": {
    "prefix": "إذا_وإذا_وإلا",
    "body": [
      "إذا (${1:الشرط1}) {",
      "\t$2",
      "} وإذا (${3:الشرط2}) {",
      "\t$4",
      "} وإلا {",
      "\t$5",
      "}"
    ],
    "description": "جملة شرطية متعددة"
  },
  "While Loop": {
    "prefix": "طالما",
    "body": [
      "طالما (${1:الشرط}) {",
      "\t$2",
      "}"
    ],
    "description": "حلقة طالما"
  },
  "For Loop": {
    "prefix": "لكل",
    "body": [
      "لكل (${1:المتغير} في ${2:القائمة}) {",
      "\t$3",
      "}"
    ],
    "description": "حلقة لكل"
  },
  "For Range": {
    "prefix": "لكل_مدى",
    "body": [
      "لكل (${1:المتغير} في مدى(${2:البداية}، ${3:النهاية})) {",
      "\t$4",
      "}"
    ],
    "description": "حلقة لكل مع مدى"
  },
  "Repeat Loop": {
    "prefix": "كرر",
    "body": [
      "كرر ${1:العدد} مرة {",
      "\t$2",
      "}"
    ],
    "description": "حلقة كرر"
  },
  "Try Catch": {
    "prefix": "حاول",
    "body": [
      "حاول {",
      "\t$1",
      "} امسك (${2:الخطأ}) {",
      "\t$3",
      "}"
    ],
    "description": "جملة حاول-امسك"
  },
  "Try Catch Finally": {
    "prefix": "حاول_كامل",
    "body": [
      "حاول {",
      "\t$1",
      "} امسك (${2:الخطأ}) {",
      "\t$3",
      "} أخيراً {",
      "\t$4",
      "}"
    ],
    "description": "جملة حاول-امسك-أخيراً"
  },
  "Class Definition": {
    "prefix": "صنف",
    "body": [
      "صنف ${1:اسم_الصنف} {",
      "\tدالة ${2:تهيئة}(هذا${3:، معاملات}) {",
      "\t\t$4",
      "\t}",
      "",
      "\tدالة ${5:طريقة}(هذا${6:، معاملات}) {",
      "\t\t$7",
      "\t}",
      "}"
    ],
    "description": "تعريف صنف جديد"
  },
  "Match Statement": {
    "prefix": "طابق",
    "body": [
      "طابق (${1:القيمة}) {",
      "\tحالة ${2:النمط1}:",
      "\t\t$3",
      "\tحالة ${4:النمط2}:",
      "\t\t$5",
      "\tافتراضي:",
      "\t\t$6",
      "}"
    ],
    "description": "جملة مطابقة"
  },
  "Lambda Function": {
    "prefix": "لامدا",
    "body": [
      "لامدا (${1:معاملات}) => ${2:التعبير}"
    ],
    "description": "دالة لامدا"
  },
  "Async Function": {
    "prefix": "غير_متزامن",
    "body": [
      "غير_متزامن دالة ${1:اسم_الدالة}(${2:معاملات}) {",
      "\tانتظر ${3:العملية}؛",
      "\tأرجع ${4:النتيجة}؛",
      "}"
    ],
    "description": "دالة غير متزامنة"
  },
  "Print Statement": {
    "prefix": "اطبع",
    "body": [
      "اطبع(\"${1:النص}\")؛"
    ],
    "description": "طباعة نص"
  },
  "Print Variable": {
    "prefix": "اطبع_متغير",
    "body": [
      "اطعب(${1:المتغير})؛"
    ],
    "description": "طباعة متغير"
  },
  "Import Statement": {
    "prefix": "استورد",
    "body": [
      "استورد ${1:الوحدة} من \"${2:المسار}\"؛"
    ],
    "description": "استيراد وحدة"
  },
  "Import With Alias": {
    "prefix": "استورد_كـ",
    "body": [
      "استورد ${1:الوحدة} كـ ${2:الاسم} من \"${3:المسار}\"؛"
    ],
    "description": "استيراد وحدة مع اسم مستعار"
  },
  "Export Statement": {
    "prefix": "صدر",
    "body": [
      "صدر ${1:العنصر}؛"
    ],
    "description": "تصدير عنصر"
  },
  "Enum Definition": {
    "prefix": "تعداد",
    "body": [
      "تعداد ${1:اسم_التعداد} {",
      "\t${2:قيمة1}،",
      "\t${3:قيمة2}،",
      "\t${4:قيمة3}",
      "}"
    ],
    "description": "تعريف تعداد"
  },
  "Data Class": {
    "prefix": "بيانات",
    "body": [
      "بيانات ${1:اسم_البيانات} {",
      "\t${2:حقل1}،",
      "\t${3:حقل2}،",
      "\t${4:حقل3}",
      "}"
    ],
    "description": "تعريف صنف بيانات"
  },
  "Context Manager": {
    "prefix": "مع",
    "body": [
      "مع ${1:المورد} كـ ${2:الاسم} {",
      "\t$3",
      "}"
    ],
    "description": "مدير سياق"
  },
  "Assert Statement": {
    "prefix": "تأكد",
    "body": [
      "تأكد(${1:الشرط}، \"${2:رسالة_الخطأ}\")؛"
    ],
    "description": "جملة تأكد"
  },
  "List Literal": {
    "prefix": "قائمة",
    "body": [
      "[${1:عنصر1}، ${2:عنصر2}، ${3:عنصر3}]"
    ],
    "description": "قائمة حرفية"
  },
  "Dictionary Literal": {
    "prefix": "قاموس",
    "body": [
      "{",
      "\t\"${1:مفتاح1}\": ${2:قيمة1}،",
      "\t\"${3:مفتاح2}\": ${4:قيمة2}",
      "}"
    ],
    "description": "قاموس حرفي"
  },
  "Comment Block": {
    "prefix": "تعليق",
    "body": [
      "# ${1:التعليق}"
    ],
    "description": "تعليق سطر واحد"
  },
  "Multi-line Comment": {
    "prefix": "تعليق_متعدد",
    "body": [
      "/*",
      " * $1",
      " */"
    ],
    "description": "تعليق متعدد الأسطر"
  },
  "Decorator": {
    "prefix": "مزين",
    "body": [
      "@${1:اسم_المزين}",
      "دالة ${2:اسم_الدالة}(${3:معاملات}) {",
      "\t$4",
      "}"
    ],
    "description": "دالة مع مزين"
  },
  "List Comprehension": {
    "prefix": "فهم_قائمة",
    "body": [
      "[${1:التعبير} لكل (${2:العنصر} في ${3:القائمة}) ${4:إذا الشرط}]"
    ],
    "description": "فهم القائمة"
  },
  "UI Button": {
    "prefix": "زر",
    "body": [
      "زر(\"${1:النص}\"، نقر: (حدث) => {",
      "\t$2",
      "})"
    ],
    "description": "زر واجهة مستخدم"
  },
  "UI Card": {
    "prefix": "بطاقة",
    "body": [
      "بطاقة {",
      "\t$1",
      "}"
    ],
    "description": "بطاقة واجهة مستخدم"
  },
  "UI Row": {
    "prefix": "صف",
    "body": [
      "صف {",
      "\t$1",
      "}"
    ],
    "description": "صف تخطيط"
  },
  "UI Column": {
    "prefix": "عمود",
    "body": [
      "عمود {",
      "\t$1",
      "}"
    ],
    "description": "عمود تخطيط"
  },
  "AI Model Load": {
    "prefix": "حمّل_نموذج",
    "body": [
      "ثابت ${1:النموذج} = حمّل.نموذج(\"${2:المسار}\")؛"
    ],
    "description": "تحميل نموذج ذكاء اصطناعي"
  },
  "AI Predict": {
    "prefix": "توقع",
    "body": [
      "ثابت ${1:النتيجة} = توقع(${2:النموذج}، ${3:المدخلات})؛"
    ],
    "description": "توقع باستخدام نموذج ذكاء اصطناعي"
  },
  "Test Function": {
    "prefix": "اختبار",
    "body": [
      "دالة اختبار_${1:الاسم}() {",
      "\tتأكد(${2:الشرط}، \"${3:رسالة_الخطأ}\")؛",
      "}"
    ],
    "description": "دالة اختبار"
  },
  "HTTP Get": {
    "prefix": "http_get",
    "body": [
      "ثابت ${1:استجابة} = http.احصل(\"${2:الرابط}\")؛"
    ],
    "description": "طلب HTTP GET"
  },
  "HTTP Post": {
    "prefix": "http_post",
    "body": [
      "ثابت ${1:استجابة} = http.أرسل(\"${2:الرابط}\"، ${3:البيانات})؛"
    ],
    "description": "طلب HTTP POST"
  }
}
